# ---------------------------------------------------------------------------
# Rudra Techno — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL (Neon/Supabase/local). Use a pooled URL on serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rudra_techno?schema=public"

# --- Phase 2: Auth.js (NextAuth) ---
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Phase 8: Payments (hybrid) ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Phase 7/10: Email + realtime (optional until those phases) ---
RESEND_API_KEY=""
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
